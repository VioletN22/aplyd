{
  "name": "aplyd",
  "version": "1.0.0",
  "description": "Job application tracker",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "npm run build:electron && electron dist/main/index.js",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc",
    "pack": "electron-builder --config electron-builder.config.js --dir",
    "dist": "electron-builder --config electron-builder.config.js",
    "install-app": "bash scripts/install-app.sh"
  },
  "keywords": [
    "job-search",
    "applications",
    "electron",
    "react",
    "typescript"
  ],
  "author": "Violet Nwe",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.17.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^40.10.5",
    "electron-builder": "^26.15.2",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
